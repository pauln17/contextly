{
  "appId": "com.pauln17.contextly",
  "productName": "Contextly",
  "directories": {
    "output": "release"
  },
  "icon": "public/icon.png",
  "files": ["dist-electron/**/*", "dist-react/**/*", "package.json"],
  "win": {
    "target": ["nsis"]
  },
