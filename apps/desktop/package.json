{
  "name": "contextly",
  "version": "0.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "main": "src/electron/main.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently -k \"vite\" \"electron .\"",
    "dev:r": "cross-env NODE_ENV=development vite",
    "dev:e": "cross-env NODE_ENV=development electron .",
    "build": "tsc -b && vite build",
    "transpile:e": "tsc --project src/electron/tsconfig.json",
    "dist:win": "npm run transpile:e && npm run build && electron-builder --win",
    "dist:mac": "npm run transpile:e && npm run build && electron-builder --mac",
    "dist:linux": "npm run transpile:e && npm run build && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "Phuc Nguyen",
  "license": "MIT",
  "dependencies": {
    "dotenv": "17.4.2",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.12"
  }
}
